# SMS configuration
# Use "console" for development (prints to server console)
# Use "twilio" for real SMS sending
SMS_BACKEND=twilio

# Twilio credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# Email configuration
# For real email sending, use SMTP backend and fill values below
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@basenacionaljovens.st
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_user@example.com
EMAIL_HOST_PASSWORD=your_password_here
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0
