    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.toast').forEach(function (el) {
                const toast = new bootstrap.Toast(el, { autohide: true, delay: 4000 });
                toast.show();
            });

            const modalEl = document.getElementById('docPreviewModal');
            if (!modalEl) return;

            const titleEl = document.getElementById('docPreviewModalLabel');
            const metaEl = document.getElementById('docPreviewModalMeta');
            const iconEl = document.getElementById('docPreviewModalIcon');
            const typeBadgeEl = document.getElementById('docPreviewTypeBadge');
            const pdfEl = document.getElementById('docPreviewPdf');
            const imgEl = document.getElementById('docPreviewImg');
            const fallbackEl = document.getElementById('docPreviewFallback');
            const loadingEl = document.getElementById('docPreviewLoading');
            const linkEl = document.getElementById('docPreviewLink');
            const openLinkEl = document.getElementById('docPreviewOpenLink');

            const typeConfig = {
                pdf: {
                    badge: 'PDF',
                    icon: 'bi-file-earmark-pdf',
                    meta: 'Documento em PDF pronto para consulta e validacao.'
                },
                image: {
                    badge: 'Imagem',
                    icon: 'bi-image',
                    meta: 'Imagem ampliada para leitura e verificacao visual.'
                },
                other: {
                    badge: 'Arquivo',
                    icon: 'bi-file-earmark-text',
                    meta: 'Se a pre-visualizacao nao estiver disponivel, abra o ficheiro numa nova aba.'
                }
            };

            function toggleLoading(isVisible) {
                loadingEl.classList.toggle('d-none', !isVisible);
            }

            function resetViewer() {
                toggleLoading(false);
                pdfEl.classList.add('d-none');
                imgEl.classList.add('d-none');
                fallbackEl.classList.add('d-none');
                pdfEl.src = '';
                imgEl.src = '';
                imgEl.alt = '';
            }

            function setTypeUI(type) {
                const config = typeConfig[type] || typeConfig.other;
                typeBadgeEl.textContent = config.badge;
                metaEl.textContent = config.meta;
                iconEl.className = `bi ${config.icon}`;
            }

            function setActionLinks(url) {
                const hasUrl = Boolean(url);

                [linkEl, openLinkEl].forEach(function (el) {
                    el.href = hasUrl ? url : '#';
                    el.classList.toggle('disabled', !hasUrl);
                    el.setAttribute('aria-disabled', hasUrl ? 'false' : 'true');
                });
            }

            function showFallback() {
                toggleLoading(false);
                pdfEl.classList.add('d-none');
                imgEl.classList.add('d-none');
                fallbackEl.classList.remove('d-none');
            }

            setTypeUI('other');
            setActionLinks('');

            pdfEl.addEventListener('load', function () {
                toggleLoading(false);
            });

            pdfEl.addEventListener('error', function () {
                showFallback();
            });

            imgEl.addEventListener('load', function () {
                toggleLoading(false);
            });

            imgEl.addEventListener('error', function () {
                showFallback();
            });

            modalEl.addEventListener('show.bs.modal', function (event) {
                const trigger = event.relatedTarget;
                if (!trigger) return;

                const url = trigger.getAttribute('data-doc-url') || '';
                const name = trigger.getAttribute('data-doc-name') || 'Documento';
                const type = trigger.getAttribute('data-doc-type') || 'other';

                titleEl.textContent = name;
                resetViewer();
                setTypeUI(type);
                setActionLinks(url);

                if (!url) {
                    showFallback();
                    return;
                }

                if (type === 'pdf') {
                    toggleLoading(true);
                    pdfEl.classList.remove('d-none');
                    pdfEl.src = url;
                } else if (type === 'image') {
                    toggleLoading(true);
                    imgEl.alt = name;
                    imgEl.classList.remove('d-none');
                    imgEl.src = url;
                } else {
                    showFallback();
                }
            });

            modalEl.addEventListener('hidden.bs.modal', function () {
                resetViewer();
                titleEl.textContent = 'Documento';
                setTypeUI('other');
                setActionLinks('');
            });
        });
    </script>
    
    
